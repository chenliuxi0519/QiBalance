{
  "entities": {
    "lead": {
      "title": "Lead",
      "description": "Contact information from potential customers",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the lead"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the lead was created"
        }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "lead",
      "description": "Collection of leads"
    }
  }
}
